{
  "name": "etoro-dashboard",
  "version": "1.0.0",
  "description": "eToro Financial Instruments Dashboard — Vue 3 + TypeScript + Vite",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@vueuse/core": "^10.11.1",
    "axios": "^1.7.9",
    "date-fns": "^3.6.0",
    "echarts": "^5.5.1",
    "lodash-es": "^4.17.21",
    "pinia": "^2.2.6",
    "pinia-plugin-persistedstate": "^3.2.3",
    "vue": "^3.5.13",
    "vue-echarts": "^6.7.3",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^18.19.68",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.32.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^4.5.5",
    "vue-tsc": "^1.8.27"
  }
}
