# ──────────────────────────────────────────────────────────────────────────────
# Upstox API credentials
# Obtain these from https://developer.upstox.com/
# ──────────────────────────────────────────────────────────────────────────────

# Your Upstox application's API key (client ID)
UPSTOX_API_KEY=your_api_key_here

# Your Upstox application's API secret (client secret)
UPSTOX_API_SECRET=your_api_secret_here

# The redirect URI registered in your Upstox developer app
# For local testing you can use: https://127.0.0.1
UPSTOX_REDIRECT_URI=https://127.0.0.1

# ──────────────────────────────────────────────────────────────────────────────
# Access token (obtained after running: python -m app auth)
# Upstox access tokens are valid for one trading day.
# Required for: holdings, positions, trades, summary, alerts
# ──────────────────────────────────────────────────────────────────────────────
UPSTOX_ACCESS_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Analytics Token  (long-lived — 1-year validity, read-only)
# Generate from: Upstox Developer Apps page → Analytics Token
# Required for: python -m app analytics *  commands
#
# Supported APIs: Full Quotes, OHLC V3, LTP V3, Historical Candles V3,
#   Market Data Feed V3, Brokerage, Market Status, Option Chain,
#   Option Contracts, Margin, Option Greeks, Instrument Search
#
# RESTRICTIONS: Cannot place orders, access holdings/positions/funds/profile.
# Valid for 1 year. Only one token allowed per account. Keep it secret.
# ──────────────────────────────────────────────────────────────────────────────
UPSTOX_ANALYTICS_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Optional settings
# ──────────────────────────────────────────────────────────────────────────────

# Override the Upstox API base URL (useful for sandbox/testing)
# UPSTOX_BASE_URL=https://api.upstox.com/v2

# Override the Analytics API base URL (no version suffix)
# UPSTOX_ANALYTICS_BASE_URL=https://api.upstox.com

# In-memory cache TTL in seconds (default: 300)
# CACHE_TTL_SECONDS=300

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO
