<?xml version="1.0" encoding="utf-8"?>
<!--
  Windows x64 — self-contained single-file release build.
  Output: bin\publish\win-x64\SujinsInvestment.exe
  Run: dotnet publish -p:PublishProfile=win-x64
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>

    <!-- Single-file EXE — no separate DLLs needed -->
    <PublishSingleFile>true</PublishSingleFile>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>

    <!-- Ahead-of-Time compilation for faster startup -->
    <PublishReadyToRun>true</PublishReadyToRun>

    <!-- Strip debug symbols from release -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>

    <!-- Output path -->
    <PublishDir>bin\publish\win-x64\</PublishDir>
  </PropertyGroup>
</Project>
