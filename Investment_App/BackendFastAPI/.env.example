# ──────────────────────────────────────────────────────────────────────────────
# Investment Portfolio Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Application
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
CACHE_TTL_SECONDS=300

# ──────────────────────────────────────────────────────────────────────────────
# Upstox broker credentials
# ──────────────────────────────────────────────────────────────────────────────
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=https://127.0.0.1
UPSTOX_ACCESS_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# eToro broker credentials
# ──────────────────────────────────────────────────────────────────────────────
ETORO_API_KEY=
ETORO_BASE_URL=https://api.etoro.com/v1

# ──────────────────────────────────────────────────────────────────────────────
# Optional Redis cache (leave blank to use in-memory cache)
# ──────────────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
