# ──────────────────────────────────────────────────────────────────────────────
# Investment Portfolio Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Application
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
CACHE_TTL_SECONDS=300

# ──────────────────────────────────────────────────────────────────────────────
# Upstox broker credentials
# ──────────────────────────────────────────────────────────────────────────────
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=https://127.0.0.1
UPSTOX_ACCESS_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# eToro broker credentials
# Get both keys from: eToro account → Settings → Trading → API Key Management
# ──────────────────────────────────────────────────────────────────────────────
ETORO_API_KEY=           # Public API Key  (x-api-key header)
ETORO_USER_KEY=          # User Key        (x-user-key header)
# ETORO_BASE_URL=https://public-api.etoro.com   # optional override

# ──────────────────────────────────────────────────────────────────────────────
# Optional Redis cache (leave blank to use in-memory cache)
# ──────────────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────────────────────────────────────
# Auth / JWT  (REQUIRED in production)
# ──────────────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ──────────────────────────────────────────────────────────────────────────────
# Default admin account seeded on first startup
# Change these before deploying to production
# ──────────────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@local.com
ADMIN_PASSWORD=Admin@123
